index=sysmon (Image="*\\ntdsutil.exe" OR OriginalFileName="ntdsutil.exe" (CommandLine="*ac i ntds*" CommandLine="*create full*") OR (CommandLine="*activate instance ntds*" CommandLine="*create full*")) OR (CommandLine="*/c copy *" CommandLine="*\\windows\\ntds\\ntds.dit*") OR (Image="*\\esentutl.exe" OR OriginalFileName="esentutl.exe" CommandLine="*\\windows\\ntds\\ntds.dit*") OR (CommandLine="*HarddiskVolumeShadowCopy*" CommandLine="*\\windows\\ntds\\ntds.dit*") OR (Image="*\\diskshadow.exe" OR OriginalFileName="diskshadow.exe" CommandLine="*/s *") OR (Image="*\\wbadmin.exe" OR OriginalFileName="WBADMIN.EXE" CommandLine="*\\windows\\ntds*") OR Image IN ("*\\NTDSDump.exe", "*\\NTDSDumpEx.exe") OR OriginalFileName IN ("NTDSDump.exe", "NTDSDumpEx.exe") OR (CommandLine="*ntds.dit*" CommandLine="*system.hiv*") OR CommandLine="*NTDSgrab.ps1*" | table _time,ComputerName,User,Image,OriginalFileName,CommandLine,CurrentDirectory,IntegrityLevel,ParentImage,ParentCommandLine,ProcessId,ParentProcessId
