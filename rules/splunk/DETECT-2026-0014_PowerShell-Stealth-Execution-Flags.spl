index=sysmon Image IN ("*\\powershell.exe", "*\\pwsh.exe") (CommandLine IN ("*-WindowStyle Hidden*", "*-WindowStyle hidden*", "*-W Hidden*", "*-W hidden*", "*-W h*") CommandLine IN ("*-NoProfile*", "*-NoP*", "*-nop*", "*-noprofile*")) OR (CommandLine IN ("*-WindowStyle Hidden*", "*-WindowStyle hidden*", "*-W Hidden*", "*-W hidden*", "*-W h*") CommandLine IN ("*-NonInteractive*", "*-NonI*", "*-noni*", "*-noninteractive*")) OR (CommandLine IN ("*-WindowStyle Hidden*", "*-WindowStyle hidden*", "*-W Hidden*", "*-W hidden*", "*-W h*") CommandLine IN ("*-NoLogo*", "*-NoL*", "*-nol*", "*-nologo*")) OR (CommandLine IN ("*-NoProfile*", "*-NoP*", "*-nop*", "*-noprofile*") CommandLine IN ("*-NonInteractive*", "*-NonI*", "*-noni*", "*-noninteractive*")) OR (CommandLine IN ("*-NoProfile*", "*-NoP*", "*-nop*", "*-noprofile*") CommandLine IN ("*-NoLogo*", "*-NoL*", "*-nol*", "*-nologo*")) OR (CommandLine IN ("*-NonInteractive*", "*-NonI*", "*-noni*", "*-noninteractive*") CommandLine IN ("*-NoLogo*", "*-NoL*", "*-nol*", "*-nologo*")) | table _time,ComputerName,User,Image,CommandLine,CurrentDirectory,IntegrityLevel,ParentImage,ParentCommandLine,ProcessId,ParentProcessId
